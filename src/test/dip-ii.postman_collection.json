    {
      "name": "tickets",
      "item": [
        {
          "name": "фильтрация",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/tickets?pageNumber=0&status=NEW&pageSize=10&sortBy=createdAt&sortDir=desc",
              "host": ["{{baseUrl}}"],
              "path": ["tickets"],
              "query": [
                { "key": "status", "value": "NEW" },
                { "key": "pageNumber", "value": "0" },
                { "key": "pageSize", "value": "10" },
                { "key": "sortBy", "value": "createdAt" },
                { "key": "sortDir", "value": "desc" }
              ]
            }
          }
        },
        {
          "name": "create",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 201\", () => pm.response.to.have.status(201));",
                  "const body = pm.response.json();",
                  "pm.expect(body).to.have.property(\"id\");",
                  "pm.environment.set(\"ticketId\", String(body.id));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Ошибка в корпоративной почте\",\n  \"description\": \"После обновления системы возникла ошибка\",\n  \"priority\": \"HIGH\",\n  \"category\": \"ACCESS\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/tickets", "host": ["{{baseUrl}}"], "path": ["tickets"] }
          }
        },
        {
          "name": "назначить",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\"assigneeId\": 3}" },
            "url": { "raw": "{{baseUrl}}/tickets/{{ticketId}}/assignee", "host": ["{{baseUrl}}"], "path": ["tickets", "{{ticketId}}", "assignee"] }
          }
        },
        {
          "name": "getById",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/tickets/{{ticketId}}", "host": ["{{baseUrl}}"], "path": ["tickets", "{{ticketId}}"] }
          }
        },
        {
          "name": "история статусов",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/tickets/{{ticketId}}/status-history", "host": ["{{baseUrl}}"], "path": ["tickets", "{{ticketId}}", "status-history"] }
          }
        },
        {
          "name": "status",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"status\":\"IN_PROGRESS\",\"reason\":\"Взято в работу\"}" },
            "url": { "raw": "{{baseUrl}}/tickets/{{ticketId}}/status", "host": ["{{baseUrl}}"], "path": ["tickets", "{{ticketId}}", "status"] }
          }
        },
        {
          "name": "эскалация",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"reason\":\"Требуется 2-я линия\"}" },
            "url": { "raw": "{{baseUrl}}/tickets/{{ticketId}}/escalate", "host": ["{{baseUrl}}"], "path": ["tickets", "{{ticketId}}", "escalate"] }
          }
        },
        {
          "name": "закрытие",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"resolutionComment\":\"тест пройден\"}" },
            "url": { "raw": "{{baseUrl}}/tickets/{{ticketId}}/close", "host": ["{{baseUrl}}"], "path": ["tickets", "{{ticketId}}", "close"] }
          }
        },
        {
          "name": "комментарий",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"commentText\": \"Проблема воспроизводится при мобильном интернете\",\n  \"internalComment\": false\n}" },
            "url": { "raw": "{{baseUrl}}/tickets/{{ticketId}}/comments", "host": ["{{baseUrl}}"], "path": ["tickets", "{{ticketId}}", "comments"] }
          }
        },
        {
          "name": "Обновить заявку",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 200\", () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test(\"Приоритет обновлён на URGENT\", () => pm.expect(body.priority).to.eql('URGENT'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"priority\":\"URGENT\",\"category\":\"HARDWARE\"}" },
            "url": { "raw": "{{baseUrl}}/tickets/{{ticketId}}", "host": ["{{baseUrl}}"], "path": ["tickets", "{{ticketId}}"] }
          }
        },
        {
          "name": "Удалить заявку (админ)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 204 No Content\", () => pm.response.to.have.status(204));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/tickets/{{ticketId}}", "host": ["{{baseUrl}}"], "path": ["tickets", "{{ticketId}}"] }
          }
        },
        {
          "name": "Чужая заявка (доступ запрещён)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status 403 Forbidden\", () => pm.response.to.have.status(403));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/tickets/99999", "host": ["{{baseUrl}}"], "path": ["tickets", "99999"] }
          }
        }
      ]
